{
  "name": "@condorhero/git-xray",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "pnpm@11.1.3",
  "description": "Diagnose a new codebase with 5 git commands before reading a single file. Generates a self-contained HTML report with charts, dark/light theme, i18n and a11y controls.",
  "author": "Condor Hero <love2xinwei@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/condorheroblog/git-xray#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/condorheroblog/git-xray.git"
  },
  "bugs": "https://github.com/condorheroblog/git-xray/issues",
  "keywords": [
    "git",
    "codebase",
    "audit",
    "churn",
    "bus-factor",
    "cli",
    "report",
    "html"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "bin": {
    "git-xray": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint",
    "prepublishOnly": "nr build",
    "release": "bumpp",
    "start": "tsx src/index.ts",
    "test": "pnpm run build && vitest",
    "typecheck": "tsc",
    "prepare": "git config core.hooksPath .githooks && simple-git-hooks && skills-npm"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:cli",
    "@antfu/ni": "catalog:cli",
    "@antfu/utils": "catalog:inlined",
    "@types/node": "catalog:types",
    "bumpp": "catalog:cli",
    "eslint": "catalog:cli",
    "nano-staged": "catalog:cli",
    "publint": "catalog:cli",
    "simple-git-hooks": "catalog:cli",
    "skills-npm": "catalog:cli",
    "tsdown": "catalog:cli",
    "tsdown-stale-guard": "catalog:testing",
    "tsnapi": "catalog:testing",
    "tsx": "catalog:cli",
    "typescript": "catalog:cli",
    "unrun": "catalog:",
    "vite": "catalog:cli",
    "vitest": "catalog:testing"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && pnpm run build && npx nano-staged"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "nano-staged": {
    "*": "eslint --fix"
  }
}
